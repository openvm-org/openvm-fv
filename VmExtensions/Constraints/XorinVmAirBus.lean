noncomputable def _memoryBus_preimage_pair {ExtF : Type} [Field ExtF]
    (air : Valid_XorinVmAir FBB ExtF) (row j : ℕ) :
    List (Interaction.MemoryBusEntry FBB) :=
  let factor := memoryBus_word_factor air row j
  [
    { multiplicity := 2013265920 * factor
      as := 2
      ptr := buffer_ptr air row + (4 * j : FBB)
      x0 := preimage_buffer_byte air (4 * j) row
      x1 := preimage_buffer_byte air (4 * j + 1) row
      x2 := preimage_buffer_byte air (4 * j + 2) row
      x3 := preimage_buffer_byte air (4 * j + 3) row
      timestamp := mem_aux_col air (111 + 3 * j) row },
    { multiplicity := factor
      as := 2
      ptr := buffer_ptr air row + (4 * j : FBB)
      x0 := preimage_buffer_byte air (4 * j) row
      x1 := preimage_buffer_byte air (4 * j + 1) row
      x2 := preimage_buffer_byte air (4 * j + 2) row
      x3 := preimage_buffer_byte air (4 * j + 3) row
      timestamp := start_timestamp air row + 3 + XorinVmAir.Soundness.cumulativePadSum air row j }
  ]

