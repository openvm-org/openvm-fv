    (h_disabled : is_enabled air row = 0) :
    entry.1 = 0 := by
  simp [memoryBus_postimage_pair, memoryBus_word_factor] at h_in
  rcases h_in with rfl | rfl <;> simp [h_disabled]

lemma mem_memoryBus_reg_pairs {ExtF : Type} [Field ExtF]
    {air : Valid_XorinVmAir FBB ExtF} {row : ℕ} {entry : FBB × List FBB}
    (h_in : entry ∈ memoryBus_reg_pairs air row) :
    entry ∈ memoryBus_buffer_reg_pair air row ∨
      entry ∈ memoryBus_input_reg_pair air row ∨
      entry ∈ memoryBus_len_reg_pair air row := by
  simp [memoryBus_reg_pairs, List.mem_append] at h_in
