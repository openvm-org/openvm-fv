@[simp]
lemma getElem__bitwiseBus_row_active {ExtF : Type} [Field ExtF]
    (air : Valid_XorinVmAir FBB ExtF) (row i : ℕ) (hi : i < 136)
    (hidx : i + 2 < (_bitwiseBus_row air row).length) :
    (_bitwiseBus_row air row)[i + 2]'hidx =
      _bitwiseBus_active_byte air row i := by
  have hprefix : (_bitwiseBus_prefix air row).length ≤ i + 2 := by
    simp [_bitwiseBus_prefix]
  change (_bitwiseBus_prefix air row ++ _bitwiseBus_active_bytes air row)[i + 2]'hidx =
    _bitwiseBus_active_byte air row i
  rw [List.getElem_append_right hprefix]
  have hsub : i + 2 - (_bitwiseBus_prefix air row).length = i := by
    simp [_bitwiseBus_prefix]
  simp [hsub, _bitwiseBus_active_bytes, _bitwiseBus_active_byte]

/-! ## Generic Bus Entry Helpers -/

@[simp]
def serialiseToList {α : Type} [Interaction.BusEntry FBB α] (rowData : List α) : List (FBB × List FBB) :=
  rowData.map Interaction.BusEntry.serialiseToList

@[simp]
def axioms {α : Type} [Interaction.BusEntry FBB α] (rowData : List α) : Prop :=
  List.Forall id (rowData.map (Interaction.BusEntry.axioms FBB))

@[simp]
def propertiesToAssume {α : Type} [Interaction.BusEntry FBB α] (rowData : List α) : Prop :=
  List.Forall id (rowData.map (Interaction.BusEntry.assume FBB))

@[simp]
def propertiesToAssert {α : Type} [Interaction.BusEntry FBB α] (rowData : List α) : Prop :=
  List.Forall id (rowData.map (Interaction.BusEntry.assert FBB))

/-! ## Aggregated Per-Row Definitions -/

@[simp]
noncomputable def busRow {ExtF : Type} [Field ExtF] (air : Valid_XorinVmAir FBB ExtF) (row : ℕ)
: List (FBB × List FBB) :=
  executionBus_row air row ++
  memoryBus_row air row ++
  programBus_row air row ++
  rangeCheckerBus_row air row ++
  bitwiseBus_row air row

