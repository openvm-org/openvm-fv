lemma mem_memoryBus_row {ExtF : Type} [Field ExtF]
    {air : Valid_XorinVmAir FBB ExtF} {row : ℕ} {entry : FBB × List FBB}
    (h_in : entry ∈ memoryBus_row air row) :
    entry ∈ memoryBus_reg_pairs air row ∨
      (∃ j, j < 34 ∧ entry ∈ memoryBus_preimage_pair air row j) ∨
      (∃ j, j < 34 ∧ entry ∈ memoryBus_input_pair air row j) ∨
      (∃ j, j < 34 ∧ entry ∈ memoryBus_postimage_pair air row j) := by
  simp [memoryBus_row, List.mem_append, memoryBus_preimage_pairs,
    memoryBus_input_pairs, memoryBus_postimage_pairs, List.mem_flatMap] at h_in
