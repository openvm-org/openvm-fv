lemma memoryBus_row_extracted_eq_row
    {F ExtF : Type} [Field F] [Field ExtF]
    {C : Type → Type → Type} [Circuit F ExtF C]
    (air : C F ExtF) (row : ℕ) :
    memoryBus_row_extracted air row = memoryBus_row air row := by
  calc
    memoryBus_row_extracted air row
      = memoryBus_reg_pairs_extracted air row ++
          memoryBus_preimage_pairs_extracted air row ++
          memoryBus_input_pairs_extracted air row ++
          memoryBus_postimage_pairs_extracted air row := by
            simpa using memoryBus_row_extracted_split air row
    _ = memoryBus_reg_pairs air row ++
          memoryBus_preimage_pairs air row ++
          memoryBus_input_pairs air row ++
          memoryBus_postimage_pairs air row := by
            rw [← memoryBus_reg_pairs_extracted_eq air row,
              ← memoryBus_preimage_pairs_extracted_eq air row,
              ← memoryBus_input_pairs_extracted_eq air row,
              ← memoryBus_postimage_pairs_extracted_eq air row]
    _ = memoryBus_row air row := by
      simp [memoryBus_row]

