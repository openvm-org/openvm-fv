lemma mem_memoryBus_row_disabled_zero {ExtF : Type} [Field ExtF]
    {air : Valid_XorinVmAir FBB ExtF} {row : ℕ}
    {entry : FBB × List FBB}
    (h_in : entry ∈ memoryBus_row air row)
    (h_disabled : is_enabled air row = 0) :
    entry.1 = 0 := by
  rcases mem_memoryBus_row h_in with h_reg | h_pre | h_input | h_post
  · rcases mem_memoryBus_reg_pairs h_reg with h_buf | h_inp | h_len
    · exact mem_memoryBus_buffer_reg_pair_disabled_zero h_buf h_disabled
    · exact mem_memoryBus_input_reg_pair_disabled_zero h_inp h_disabled
    · exact mem_memoryBus_len_reg_pair_disabled_zero h_len h_disabled
  · rcases h_pre with ⟨j, hj, h_pair⟩
    exact mem_memoryBus_preimage_pair_disabled_zero h_pair h_disabled
  · rcases h_input with ⟨j, hj, h_pair⟩
    exact mem_memoryBus_input_pair_disabled_zero h_pair h_disabled
  · rcases h_post with ⟨j, hj, h_pair⟩
    exact mem_memoryBus_postimage_pair_disabled_zero h_pair h_disabled

