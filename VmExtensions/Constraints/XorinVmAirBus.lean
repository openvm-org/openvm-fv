/-! ## Simplified constrain_interactions -/

noncomputable def constrain_interactions_simplified {F ExtF : Type} [Field F] [Field ExtF]
    (air : Valid_XorinVmAir F ExtF) : Prop :=
  air.buses = fun index =>
    if index = 0 then (List.range (air.last_row + 1)).flatMap (executionBus_row air)
    else if index = 1 then (List.range (air.last_row + 1)).flatMap (memoryBus_row air)
    else if index = 2 then (List.range (air.last_row + 1)).flatMap (programBus_row air)
    else if index = 3 then (List.range (air.last_row + 1)).flatMap (rangeCheckerBus_row air)
    else if index = 6 then (List.range (air.last_row + 1)).flatMap (bitwiseBus_row air)
    else []

